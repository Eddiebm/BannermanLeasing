# --- Cloudflare Pages / Wrangler environment secrets ---
# Set these as encrypted secrets in the Cloudflare Pages dashboard
# (Settings > Environment variables > Add variable > Encrypt)

ANTHROPIC_API_KEY=sk-ant-...
OPENAI_API_KEY=sk-...
GOOGLE_AI_API_KEY=AIza...

# Secret token used to authenticate the cron endpoint
CRON_SECRET=change-me-to-a-random-string

# --- Optional Supabase integration ---
# Leave blank to use localStorage-only mode
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=eyJ...
